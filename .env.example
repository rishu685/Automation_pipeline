# MongoDB Connection String (Atlas free tier or local MongoDB)
MONGO_URI=mongodb://localhost:27017/onboarding

# Gemini API Key (Get a free key from Google AI Studio: https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Notion Settings (Create an integration: https://www.notion.so/my-integrations)
NOTION_TOKEN=ntn_your_notion_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Slack Settings (Create a Slack App with Incoming Webhook in your workspace)
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Resend Settings (Get a free key: https://resend.com/ - 3,000 free emails/mo)
RESEND_API_KEY=re_your_resend_api_key_here

# The email address to send onboarding messages from
# For testing on Resend's free tier sandbox, you MUST use: onboarding@resend.dev
SENDER_EMAIL=onboarding@resend.dev
